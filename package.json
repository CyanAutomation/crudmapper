{
  "name": "crudmapper",
  "version": "1.0.0",
  "description": "Map and visualize CRUD permissions across role definitions",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,css}\""
  },
  "keywords": [
    "crud",
    "permissions",
    "roles",
    "mapping"
  ],
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
